\pard\ltrpar\tx720\f0\ltrch\lang1033 MERGE INTO TargetTable AS T\par
USING SourceTable AS S\par
ON T.PrimaryKey = S.PrimaryKey\par
WHEN MATCHED THEN\par
    UPDATE SET T.Column1 = S.Column1, T.Column2 = S.Column2\par
WHEN NOT MATCHED THEN\par
    INSERT (Column1, Column2)\par
    VALUES (S.Column1, S.Column2);\par
\par
\par
\par
\par
Examble\'85\'85\'85.\par
