MERGE INTO Doctor AS D\par
USING NewDoctors AS N\par
ON D.DoctorID = N.DoctorID\par
WHEN MATCHED THEN\par
    UPDATE SET D.Phone = N.Phone, D.Email = N.Email\par
WHEN NOT MATCHED THEN\par
    INSERT (DoctorID, Name, Email, Phone, Specialty, YearsOfExperience)\par
    VALUES (N.DoctorID, N.Name, N.Email, N.Phone, N.Specialty, N.YearsOfExperience);\par
\par
